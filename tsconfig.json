{
  "compilerOptions": {
    "allowJs": false,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["rules/**/*.ts", "rules/**/*.d.ts"]
}
