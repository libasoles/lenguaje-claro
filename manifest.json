{
  "manifest_version": 3,
  "name": "Lenguaje claro",
  "version": "0.1.0",
  "description": "Revisa y mejora la escritura en Google Docs - Detecta arcaísmos, voz pasiva y queísmo",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*"],
      "js": [
        "rules/index.js",
        "rules/arcaismos.js",
        "rules/voz-pasiva.js",
        "rules/queismo.js",
        "content/reader.js",
        "content/highlighter.js",
        "content/panel.js",
        "content/content.js"
      ],
      "css": ["panel/panel.css"],
      "run_at": "document_start"
    }
  ]
}
