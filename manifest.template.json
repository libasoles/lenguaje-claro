{
  "_comment": "Edita aqui y luego corre `npm run build` para generar `dist/manifest.json` con el client ID tomado de .env.",
  "manifest_version": 3,
  "name": "Lenguaje claro",
  "version": "0.1.1",
  "description": "Revisa y mejora la escritura en Google Docs - Detecta arcaísmos, voz pasiva y queísmo",
  "permissions": ["storage", "identity"],
  "host_permissions": ["https://docs.googleapis.com/*"],
  "oauth2": {
    "client_id": "__CHROME_OAUTH_CLIENT_ID__",
    "scopes": ["https://www.googleapis.com/auth/documents"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*", "rules/patterns.json"],
      "matches": ["https://docs.google.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content/canvas-patcher.js", "content/kix-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://docs.google.com/*"],
      "js": [
        "vendor/compromise.min.js",
        "vendor/es-compromise.min.js",
        "content/index.js"
      ],
      "css": ["panel/panel.css"],
      "run_at": "document_idle"
    }
  ]
}
